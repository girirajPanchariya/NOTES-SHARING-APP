generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShareType {
  ONE_TIME
  TIME
}

enum AccessType {
  PUBLIC
  PASSWORD
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String

  notes     Note[]

  createdAt DateTime @default(now())
}

model Note {
  id          String   @id @default(cuid())

  title       String
  content     String

  userId      String
  user        User @relation(fields: [userId], references: [id])

  shareLinks  ShareLink[]

  createdAt   DateTime @default(now())
}

model ShareLink {
  id           String @id @default(cuid())

  token        String @unique

  password     String?

  accessType   AccessType

  shareType    ShareType

  expiresAt    DateTime?

  revoked      Boolean @default(false)

  used         Boolean @default(false)

  viewCount    Int @default(0)

  noteId       String

  note         Note @relation(fields:[noteId], references:[id])

  createdAt    DateTime @default(now())
}